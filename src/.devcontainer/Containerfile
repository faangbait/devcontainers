FROM registry.access.redhat.com/ubi10:latest AS builder
ADD --unpack=true https://github.com/BurntSushi/ripgrep/releases/download/15.2.0/ripgrep-15.2.0-x86_64-unknown-linux-musl.tar.gz /mnt

FROM registry.access.redhat.com/ubi10:latest AS builder-agents
RUN dnf install -y --releasever 10 --setopt=install_weak_deps=0 --nodocs \
        ca-certificates crontabs

WORKDIR /mnt/init
ADD --chmod=+x https://claude.ai/install.sh ./01_claude
ADD --chmod=+x https://chatgpt.com/codex/install.sh ./02_codex
ADD --chmod=+x https://opencode.ai/install ./03_opencode
ADD --chmod=+x https://raw.githubusercontent.com/8b-is/smart-tree/main/scripts/install.sh ./04_smart-tree

# These installers assume a real $HOME to unpack config/cache/state into, but
# all we want out of them is the resolved binary - everything else in this
# stage gets discarded. Payload locations below were found by running each
# installer against a scratch $HOME and diffing the filesystem for new files:
#   claude     -> $HOME/.local/bin/claude (symlink to the real versioned binary)
#   codex      -> $HOME/.codex/packages/standalone/releases/<ver>/bin/codex
#   opencode   -> $HOME/.opencode/bin/opencode
#   smart-tree -> installs straight to $INSTALL_DIR, no $HOME payload
# ENV HOME=/mnt/agents-home
# ENV INSTALL_DIR=/mnt/agents-bin
# ENV CODEX_INSTALL_DIR=/mnt/agents-bin
# ENV CODEX_NON_INTERACTIVE=1

RUN <<EOF
# mkdir -p "$HOME" "$INSTALL_DIR"
# run-parts /mnt/init/
# rm -f "$INSTALL_DIR/codex"
# cp -L "$HOME/.local/bin/claude" "$INSTALL_DIR/claude"
# cp -L "$HOME"/.codex/packages/standalone/releases/*/bin/codex "$INSTALL_DIR/codex"
# cp -L "$HOME/.opencode/bin/opencode" "$INSTALL_DIR/opencode"
# chmod +x "$INSTALL_DIR"/*
EOF

FROM registry.access.redhat.com/ubi10/ubi-minimal:latest AS base

### CORE COMPONENTS.
RUN <<-EOT
microdnf install -y --releasever 10 --setopt=install_weak_deps=0 --nodocs \
    crypto-policies-scripts acl shadow-utils ca-certificates gnupg2 openssl-devel \
    crontabs wget git-core \
    findutils file diffutils ncurses ncurses-devel \
    iputils nmap-ncat bind-utils \
    tar gzip xz-devel xz zlib-devel \
    gdb-gdbserver patch make gcc \
    python3.14 python3.14-pip python3.14-Cython python3.14-psycopg2 \
    python3.14-requests python3.14-setuptools \
    libffi-devel libxml2-devel sqlite-devel \
    nodejs24 nodejs24-npm chkconfig && \
    microdnf clean all
EOT

COPY --from=builder /mnt/ripgrep-*/rg /usr/local/bin/

RUN ln -sf /usr/bin/python3.14 /usr/local/bin/python && \
    ln -sf /usr/bin/node-24 /usr/local/bin/node && \
    ln -sf /usr/bin/npm-24 /usr/local/bin/npm && \
    ln -sf /usr/bin/npx-24 /usr/local/bin/npx

LABEL maintainer="S Smith <root@madeof.glass>"
ENV container=oci
ENV LANG=C.UTF-8

CMD ["/bin/bash"]

# ---------------------------------------------------------------------------
# `agents` extends `base` with the agentic CLIs (claude, codex, opencode,
# smart-tree) as plain binaries in /usr/local/bin. No $HOME involved at build
# or run time - each tool's config/state is redirected to a mounted volume at
# runtime via its own env var override (CLAUDE_CONFIG_DIR, CODEX_HOME, the
# XDG_*_HOME vars for opencode), set in the devcontainer.json containerEnv.
#
# Build+tag each stage independently:
#   docker build --target base   -t faangbait/workspaces:base   src/base-ubi/.devcontainer
#   docker build --target agents -t faangbait/workspaces:agents src/base-ubi/.devcontainer
# ---------------------------------------------------------------------------
FROM base AS agents

COPY --from=builder-agents /mnt/agents-bin/ /usr/local/bin/

RUN python3.14 -m pip install --no-cache-dir pipx && \
    PIPX_HOME=/usr/local/pipx PIPX_BIN_DIR=/usr/local/bin python3.14 -m pipx install spec-kitty-cli && \
    npm install -g context-mode

# ---------------------------------------------------------------------------
# `python` extends `agents`. Same pattern as the other language variants:
# FROM agents (or base) AS <name>, add what's specific to that stack.
# ---------------------------------------------------------------------------
FROM agents AS python

ADD --chmod=+x https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 /usr/local/bin/yq

# ---------------------------------------------------------------------------
# `django` extends `python`.
# ---------------------------------------------------------------------------
FROM python AS django

RUN python3.14 -m pip install --no-cache-dir django
